# ─────────────────────────────────────────────────────────────────────────────
# The Technical Draft — Environment Variables
# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit personal data to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Social links (profile sidebar & footer) ───────────────────────────────
# Leave any of these empty (or remove the line) to hide that social link.

PUBLIC_SOCIAL_GITHUB=https://github.com/x86txt
PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/in/mevanssecurity
PUBLIC_SOCIAL_EMAIL=hello@mattevans.cloud

# ── "Edit this post" button ────────────────────────────────────────────────
# Full URL prefix to your repo's edit page. The post file path is appended automatically.
# Example for GitHub: https://github.com/your-username/your-repo/edit/main/
PUBLIC_EDIT_POST_URL=https://github.com/your-username/your-repo/edit/main/

# ── Google Search Console verification (optional) ─────────────────────────
# PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token
